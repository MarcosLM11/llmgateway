{
  "uid": "llmgateway-overview",
  "title": "LLM Gateway - Overview",
  "tags": ["llmgateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cache Hit Rate (last 5m)",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [{
        "expr": "sum(rate(llmgateway_cache_lookups_total{result=\"hit\"}[5m])) / sum(rate(llmgateway_cache_lookups_total[5m]))",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0.3, "color": "yellow"},
              {"value": 0.7, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Provider latency avg",
      "gridPos": {"x": 8, "y": 0, "w": 16, "h": 6},
      "targets": [{
        "expr": "rate(llmgateway_provider_latency_seconds_sum[1m]) / rate(llmgateway_provider_latency_seconds_count[1m])",
        "legendFormat": "{{provider}} - {{status}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cache lookups per second",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [{
        "expr": "sum by (result) (rate(llmgateway_cache_lookups_total[1m]))",
        "legendFormat": "{{result}}",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tokens consumed per second",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [{
        "expr": "sum by (type) (rate(llmgateway_tokens_consumed_sum[1m]))",
        "legendFormat": "{{type}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    }
  ]
}